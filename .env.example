# ============================================
# Resolver.tech - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values

# ============================================
# Database Configuration
# ============================================
DB_PASSWORD=resolver_secure_password_123

# ============================================
# API Keys
# ============================================
# Get your API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key-here

# ============================================
# Security
# ============================================
# Generate a secure key with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long

# ============================================
# URLs (for production, change these)
# ============================================
FRONTEND_URL=https://resolver.tech
API_URL=https://api.resolver.tech

# ============================================
# Optional: Email Configuration (for notifications)
# ============================================
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.mailgun.org
# MAIL_PORT=587
# MAIL_USERNAME=postmaster@resolver.tech
# MAIL_PASSWORD=your-mail-password
# MAIL_ENCRYPTION=tls
# MAIL_FROM_ADDRESS=noreply@resolver.tech
# MAIL_FROM_NAME="Resolver Assistant"

# ============================================
# Optional: Redis (for caching and queues)
# ============================================
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379

# ============================================
# Development Settings (don't change for Docker)
# ============================================
APP_ENV=production
APP_DEBUG=false
